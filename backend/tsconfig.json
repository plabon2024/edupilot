{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "./",
    "outDir": "./dist",
    "target": "ES2023",
    "types": ["node", "express"],
    "strict": true,
    "esModuleInterop": true,
    // "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src","prisma.config.ts"],
  "exclude": ["node_modules","dist","api"]
}
