# Frontend Environment Variables
# Copy this file to .env.local and update with your actual values

# === PRODUCTION ===
# Backend base URL (without /api path)
# Example: https://api.yourdomain.com or https://yourdomain.com:5000
NEXT_PUBLIC_AUTH_URL=https://your-backend-url.com

# Backend API endpoint (includes /api/v1 path)
# Example: https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_BASE_URL=https://your-backend-url.com/api/v1

# === LOCAL DEVELOPMENT ===
# Uncomment and update these for local development
# NEXT_PUBLIC_AUTH_URL=http://localhost:5000
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1
